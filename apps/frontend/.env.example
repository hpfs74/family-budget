# API endpoint — in production this is /api/ (proxied via CloudFront)
VITE_API_ENDPOINT=https://your-api-gateway-url.com/prod/

# Cognito OAuth2 — values come from the AuthStack CDK outputs
VITE_COGNITO_DOMAIN=budget-matteo-cool.auth.eu-south-1.amazoncognito.com
VITE_COGNITO_CLIENT_ID=your-cognito-client-id
VITE_COGNITO_REDIRECT_URI=http://localhost:4200/callback
VITE_COGNITO_LOGOUT_URI=http://localhost:4200/login
